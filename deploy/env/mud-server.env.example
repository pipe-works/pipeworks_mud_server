# PipeWorks MUD Server — host-managed environment variable reference for Luminal.
#
# These are not loaded from a file by the service unit; each variable is set as
# an inline Environment= line in the systemd unit.  This file documents every
# recognised variable and its Luminal default so the unit can be reproduced from
# scratch on a new host.
#
# See deploy/systemd/pipeworks-dev.service for the active unit template.

# ---------------------------------------------------------------------------
# Bind address
# ---------------------------------------------------------------------------

# Backend listens on localhost only when fronted by nginx.
MUD_HOST=127.0.0.1
MUD_PORT=18000

# ---------------------------------------------------------------------------
# Runtime paths
# ---------------------------------------------------------------------------

# Canonical SQLite runtime database.  Must live outside the repo checkout.
MUD_DB_PATH=/srv/work/pipeworks/runtime/pipeworks_mud_server/mud.db

# Root of the pipe-works-world-policies checkout used for artifact imports.
MUD_POLICY_EXPORTS_ROOT=/srv/work/pipeworks/repos/pipe-works-world-policies

# World package root.  Defaults to data/worlds/ inside the repo if unset.
# MUD_WORLDS_ROOT=/srv/work/pipeworks/repos/pipeworks_mud_server/data/worlds

# ---------------------------------------------------------------------------
# Integrations
# ---------------------------------------------------------------------------

# Name-generation API.  Point at the backend port directly (not the nginx
# front door) to avoid TLS certificate verification issues for internal calls.
# The namegen-api backend binds to 127.0.0.1:8360 on Luminal.
MUD_NAMEGEN_BASE_URL=http://127.0.0.1:8360

# Namegen package id that the character provisioning flow requests.
# Must match an imported package in the namegen-api SQLite database.
# MUD_NAMEGEN_PACKAGE_ID=2

# Entity-state generation API base URL.
# MUD_ENTITY_STATE_BASE_URL=http://127.0.0.1:<port>

# Ollama base URL used for translation rendering.
# MUD_TRANSLATION_OLLAMA_URL=http://127.0.0.1:11434
